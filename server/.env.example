# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Client origin (for CORS) ────────────────────────────
CLIENT_URL=http://localhost:5173

# ── PostgreSQL ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YourPostgreSQLpassword@localhost:5432/wedding_db

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# Admin password (plain text here — server hashes it on first run)
# After seeding, remove this line for security
ADMIN_PASSWORD=your-admin_password_here!

# ── Cloudinary ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=joyce-derick-wedding
